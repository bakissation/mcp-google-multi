{
  "name": "mcp-google-multi",
  "version": "3.0.0",
  "description": "MCP server for Gmail, Google Drive, Calendar, Sheets, Docs, and Contacts with multi-account support",
  "type": "module",
  "license": "MIT",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "google",
    "gmail",
    "google-drive",
    "google-calendar",
    "google-sheets",
    "google-docs",
    "google-contacts",
    "claude",
    "claude-code"
  ],
  "scripts": {
    "build": "tsc && chmod +x dist/index.js",
    "watch": "tsc --watch",
    "auth": "node dist/index.js auth --account",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "dotenv": "^17.4.0",
    "googleapis": "^171.4.0",
    "mime-types": "^3.0.2",
    "open": "^11.0.0",
    "server-destroy": "^1.0.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/mime-types": "^3.0.1",
    "@types/node": "^25.6.0",
    "@types/server-destroy": "^1.0.3",
    "eslint": "^10.2.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.1",
    "vitest": "^4.1.5"
  }
}
